# ==========================================
# Configurações do Google Gemini
# ==========================================
# Gere sua chave no Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=cole_sua_chave_aqui_sem_aspas

# ==========================================
# Caminhos e Diretórios Locais
# ==========================================
# Caminho absoluto para a pasta onde os anexos e PDFs serão salvos
# Exemplo Windows: C:/Users/SeuUsuario/Documents/Certificados_AutoApply
# Exemplo Linux/Mac: /home/usuario/certificados_autoapply
Certificado_Drive=caminho_absoluto_para_sua_pasta_aqui